<?xml version='1.0' encoding='utf-8'?>
<workbook original-version="2024.1" source-build="agent-map-codex" source-platform="mac" version="2024.1">
  <document-format-change-manifest>
    <_.fcp.AccessibleZoneTabOrder.true...style />
  </document-format-change-manifest><preferences>
    <preference name="ui.encoding.shelf.height" value="24" />
  </preferences><datasources>
    <datasource caption="AgentMap Data" inline="true" name="federated.1" version="18.1">
      <connection class="textscan" dbname="sample_sales.csv" directory="Data" filename="sample_sales.csv" />
      <metadata-records>
        <metadata-record class="column">
          <local-name>date</local-name>
          <remote-name>date</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>region</local-name>
          <remote-name>region</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>segment</local-name>
          <remote-name>segment</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>category</local-name>
          <remote-name>category</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>sub_category</local-name>
          <remote-name>sub_category</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>channel</local-name>
          <remote-name>channel</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>visitors</local-name>
          <remote-name>visitors</remote-name>
          <remote-type>real</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>orders</local-name>
          <remote-name>orders</remote-name>
          <remote-type>real</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>revenue</local-name>
          <remote-name>revenue</remote-name>
          <remote-type>real</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>cost</local-name>
          <remote-name>cost</remote-name>
          <remote-type>real</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>discount</local-name>
          <remote-name>discount</remote-name>
          <remote-type>real</remote-type>
        </metadata-record><metadata-record class="column">
          <local-name>test_group</local-name>
          <remote-name>test_group</remote-name>
          <remote-type>wstring</remote-type>
        </metadata-record>
      </metadata-records>
    </datasource>
  </datasources><worksheets>
    <worksheet name="Executive Overview">
      <layout-options />
      <table>
        <view>
          <datasource-dependencies datasource="federated.1">
            <column caption="Revenue" datatype="real" name="[revenue]" role="measure" type="quantitative" />
            <column caption="Profit Margin" datatype="real" name="[profit_margin]" role="measure" type="quantitative" />
            <column caption="Conversion Rate" datatype="real" name="[conversion_rate]" role="measure" type="quantitative" />
            <column caption="Average Order Value" datatype="real" name="[average_order_value]" role="measure" type="quantitative" />
          </datasource-dependencies>
        </view>
      </table>
    </worksheet><worksheet name="Drivers &amp; Diagnostics">
      <layout-options />
      <table>
        <view>
          <datasource-dependencies datasource="federated.1">
            <column caption="Revenue" datatype="real" name="[revenue]" role="measure" type="quantitative" />
            <column caption="Profit Margin" datatype="real" name="[profit_margin]" role="measure" type="quantitative" />
            <column caption="Conversion Rate" datatype="real" name="[conversion_rate]" role="measure" type="quantitative" />
            <column caption="Average Order Value" datatype="real" name="[average_order_value]" role="measure" type="quantitative" />
          </datasource-dependencies>
        </view>
      </table>
    </worksheet><worksheet name="Action Board">
      <layout-options />
