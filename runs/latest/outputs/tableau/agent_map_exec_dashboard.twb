  </worksheets><dashboards>
    <dashboard name="Executive Overview">
      <style>
        <style-rule element="dashboard" />
      </style><zones>
        <zone id="1" name="KPI cards with sparkline and delta" type-v2="layout-basic" x="0" y="0" w="1200" h="100">KPI cards with sparkline and delta</zone>
        <zone id="2" name="Trend line section" type-v2="layout-basic" x="0" y="120" w="1200" h="100">Trend line section</zone>
        <zone id="3" name="Category and region comparison" type-v2="layout-basic" x="0" y="240" w="1200" h="100">Category and region comparison</zone>
        <zone id="4" name="Action summary card" type-v2="layout-basic" x="0" y="360" w="1200" h="100">Action summary card</zone>
      </zones>
    </dashboard><dashboard name="Drivers &amp; Diagnostics">
      <style>
        <style-rule element="dashboard" />
      </style><zones>
        <zone id="1" name="Funnel efficiency view" type-v2="layout-basic" x="0" y="0" w="1200" h="100">Funnel efficiency view</zone>
        <zone id="2" name="A/B test lift card" type-v2="layout-basic" x="0" y="120" w="1200" h="100">A/B test lift card</zone>
        <zone id="3" name="Region/category ranking with max/min emphasis" type-v2="layout-basic" x="0" y="240" w="1200" h="100">Region/category ranking with max/min emphasis</zone>
        <zone id="4" name="Knowledge base insights" type-v2="layout-basic" x="0" y="360" w="1200" h="100">Knowledge base insights</zone>
      </zones>
    </dashboard><dashboard name="Action Board">
