        <view>
          <datasource-dependencies datasource="federated.1">
            <column caption="Revenue" datatype="real" name="[revenue]" role="measure" type="quantitative" />
            <column caption="Profit Margin" datatype="real" name="[profit_margin]" role="measure" type="quantitative" />
            <column caption="Conversion Rate" datatype="real" name="[conversion_rate]" role="measure" type="quantitative" />
            <column caption="Average Order Value" datatype="real" name="[average_order_value]" role="measure" type="quantitative" />
          </datasource-dependencies>
        </view>
      </table>
    </worksheet><worksheet name="Data Table">
      <layout-options />
      <table>
        <view>
          <datasource-dependencies datasource="federated.1">
            <column caption="Revenue" datatype="real" name="[revenue]" role="measure" type="quantitative" />
            <column caption="Profit Margin" datatype="real" name="[profit_margin]" role="measure" type="quantitative" />
            <column caption="Conversion Rate" datatype="real" name="[conversion_rate]" role="measure" type="quantitative" />
